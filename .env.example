NODE_ENV=development
PORT=4001
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000

DATABASE_URL="postgresql://user:password@host:5432/nhachung?schema=public"

# Generate strong secrets, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace_with_strong_random_secret
JWT_REFRESH_TTL=30d

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=nhachung
AWS_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=true
AWS_PUBLIC_URL=

# Optional: enables the AI assistant. Leave blank to run in degraded mode.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
